[sub_resource type="ViewportTexture" id="ViewportTexture_gjhfo"]
viewport_path = NodePath("CLOCK2/SubViewport")

[sub_resource type="LabelSettings" id="LabelSettings_gjhfo"]
font_size = 21

[sub_resource type="GDScript" id="GDScript_fuu7u"]
script/source = "extends Label

func _process(delta: float) -> void:
	var min = floor(EnemyAI.time / 60.0)
	var sec = int(floor(EnemyAI.time)) % 60
	text = \"%02d : %02d\" % [min, sec]
"

[sub_resource type="ViewportTexture" id="ViewportTexture_fuu7u"]
viewport_path = NodePath("AAANNIEPLUSH/Sprite3D/SubViewport2")

[sub_resource type="GDScript" id="GDScript_gjhfo"]
script/source = "extends Label

var player : Node3D

func _ready() -> void:
	player = get_tree().get_first_node_in_group(\"Player\")

func _process(delta: float) -> void:
	if player != null:
		text = str(int(player.battery)) + \"%\"
"

