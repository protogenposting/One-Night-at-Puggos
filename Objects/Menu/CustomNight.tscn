[sub_resource type="GDScript" id="GDScript_4wlhj"]
script/source = "extends Control

func _process(delta: float) -> void:
	if !EnemyAI.ultraMode:
		if Input.is_action_just_pressed(\"UltraMode\"):
			EnemyAI.ultraMode = true
			
			$AnimationPlayer.play(\"activate\")
"

[sub_resource type="GDScript" id="GDScript_822us"]
script/source = "extends Button

func _on_pressed() -> void:
	get_tree().change_scene_to_file(\"res://Rooms/MainMenu.tscn\")
	
	EnemyAI.ultraMode = false
"

[sub_resource type="GDScript" id="GDScript_1auxk"]
script/source = "extends Button


func _on_pressed() -> void:
	EnemyAI._start()
"

[sub_resource type="GDScript" id="GDScript_vpk8s"]
script/source = "extends Button

func _on_pressed() -> void:
	for character in get_parent().get_node(\"HBoxContainer\").get_children():
		character.slider.value -= 1
"

[sub_resource type="GDScript" id="GDScript_5ggrp"]
script/source = "extends Button

func _on_pressed() -> void:
	for character in get_parent().get_node(\"HBoxContainer\").get_children():
		character.slider.value += 1
"

