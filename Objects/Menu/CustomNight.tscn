[sub_resource type="GDScript" id="GDScript_4wlhj"]
script/source = "extends Control

func _ready() -> void:
	if EnemyAI.ultraMode:
		$AnimationPlayer.play(\"activate\")

func _process(delta: float) -> void:
	$HellMode.visible = EnemyAI.hellMode
	
	if !EnemyAI.ultraMode:
		$UltraMode.visible = false
		
		if Input.is_action_just_pressed(\"UltraMode\"):
			EnemyAI.ultraMode = true
			
			$AnimationPlayer.play(\"activate\")
	else:
		$UltraMode.visible = true
		
		if Input.is_action_just_pressed(\"UltraMode\"):
			EnemyAI.ultraMode = false
			
			$AnimationPlayer.play(\"RESET\")
"

