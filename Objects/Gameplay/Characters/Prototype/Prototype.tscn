[sub_resource type="GDScript" id="GDScript_srblt"]
script/source = "extends Panel

var isCloned : bool = false

func _ready() -> void:
	position = Vector2(randf_range(0,1920),randf_range(0,1080))
	
	if isCloned:
		$PopUp.play()

func _process(delta: float) -> void:
	if !isCloned:
		visible = false

func _clone():
	var child = self.duplicate()
	
	child.isCloned = true
	
	add_sibling(child)
	
	child.visible = true


func _on_button_pressed() -> void:
	queue_free()
"

