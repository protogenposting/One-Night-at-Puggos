[sub_resource type="GDScript" id="GDScript_i7nle"]
script/source = "extends Sprite2D

var isInPlayer : bool = true

func _ready() -> void:
	if !isInPlayer:
		_toggle()

func _toggle():
	visible = !visible
	
	get_tree().create_timer(0.5).timeout.connect(_toggle)
"

